{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://the-greatest-shortcoming/metadata/draft-metadata.schema.json",
  "title": "Draft metadata interface",
  "description": "The contract the PDF-reading agent (Stage 2) fills in from a draft's extract.json. Stage 3 (audit) derives a rename plan from `constructs`, `chapters`, and `extra_renames`; Stage 4 (apply) executes it. Content fields (definition, summary, concept, teaser) double as the new copy written into the site, so the metadata is the single source of truth.",
  "type": "object",
  "required": ["draft", "constructs", "chapters"],
  "additionalProperties": false,
  "properties": {
    "draft": {
      "type": "object",
      "required": ["source_pdf", "version", "pages", "sha256", "ingested"],
      "additionalProperties": true,
      "properties": {
        "source_pdf": { "type": "string" },
        "version": { "type": "integer" },
        "pages": { "type": "integer" },
        "sha256": { "type": "string" },
        "ingested": { "type": "string", "description": "ISO date the draft was read" },
        "title_line": { "type": "string", "description": "subtitle as printed on the title page" }
      }
    },
    "constructs": {
      "type": "array",
      "description": "The book's named analytical constructs/registers.",
      "items": {
        "type": "object",
        "required": ["id", "canonical_name", "status"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "current machine id (underscore form)" },
          "prev_id": { "type": ["string", "null"] },
          "canonical_name": { "type": "string" },
          "prev_name": { "type": ["string", "null"] },
          "slug": { "type": ["string", "null"], "description": "hyphen id / URL slug" },
          "prev_slug": { "type": ["string", "null"] },
          "short_label": { "type": ["string", "null"] },
          "prev_short_label": { "type": ["string", "null"] },
          "aliases_deprecated": {
            "type": "array", "items": { "type": "string" },
            "description": "old display spellings to rename to canonical_name (case variants auto-generated by the auditor)"
          },
          "preserve_terms": {
            "type": "array", "items": { "type": "string" },
            "description": "bare words that LOOK related but must NOT be renamed (e.g. 'ecofascism' the movement)"
          },
          "definition": { "type": "string", "description": "canonical definition, verbatim from the draft" },
          "status": { "enum": ["unchanged", "renamed", "new", "removed"] }
        }
      }
    },
    "chapters": {
      "type": "array",
      "description": "Authoritative chapter list (order + titles from the draft TOC).",
      "items": {
        "type": "object",
        "required": ["num", "slug", "title", "status", "source"],
        "additionalProperties": false,
        "properties": {
          "num": { "type": "string", "description": "zero-padded, '00' = preface" },
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "prev_slug": { "type": ["string", "null"], "description": "old site slug this maps from; null if new" },
          "prev_title": { "type": ["string", "null"] },
          "era_id": { "type": ["string", "null"], "description": "scrolly-step id, if this chapter is a timeline step" },
          "prev_era_id": { "type": ["string", "null"] },
          "era_label": { "type": ["string", "null"], "description": "small caption (year range or phrase)" },
          "concept": { "type": ["string", "null"], "description": "mechanism named in the chapter" },
          "teaser": { "type": ["string", "null"], "description": "one-line hook" },
          "pitch": { "type": ["string", "null"], "description": "1–2 sentence pitch for the TOC card" },
          "summary": { "type": "string", "description": "paragraph summary" },
          "key_terms": { "type": "array", "items": { "type": "string" } },
          "source": { "enum": ["pdf", "landing.js", "pdf+landing.js", "manuscript"], "description": "provenance of the summary" },
          "status": { "enum": ["unchanged", "renamed", "renumbered", "renamed+renumbered", "new"] }
        }
      }
    },
    "extra_renames": {
      "type": "object",
      "description": "Special-case renames not derivable from constructs/chapters (e.g. a JS component symbol). Use sparingly; everything here is applied verbatim and flagged in the audit report for human review.",
      "additionalProperties": false,
      "properties": {
        "tokens": {
          "type": "object", "additionalProperties": { "type": "string" },
          "description": "word-boundary old→new (ids, slugs, labels)"
        },
        "phrases": {
          "type": "object", "additionalProperties": { "type": "string" },
          "description": "substring old→new (case-sensitive display strings)"
        }
      }
    },
    "definition_blocks": {
      "type": "array",
      "description": "Substantive prose rewrites: replace a unique anchor block with new text (used where a rename alone wouldn't capture the new framing).",
      "items": {
        "type": "object",
        "required": ["file", "find", "replace"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string" },
          "find": { "type": "string", "description": "unique substring anchor present in the file" },
          "replace": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
