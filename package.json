{
  "name": "the-greatest-shortcoming",
  "version": "0.2.0",
  "private": true,
  "description": "Jekyll site for The Greatest Shortcoming. Tailwind CSS built via the tailwindcss CLI.",
  "type": "module",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i assets/css/src/main.css -o assets/css/dist/main.css --minify",
    "dev:css": "tailwindcss -i assets/css/src/main.css -o assets/css/dist/main.css --watch",
    "render": "node render/harness/capture.mjs",
    "encode": "node render/encode.mjs",
    "render:all": "npm run render && npm run encode",
    "bake:landing": "node render/bake-landing.mjs"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.5.4",
    "playwright": "^1.61.1",
    "postcss": "^8.5.20",
    "tailwindcss": "^3.4.17",
    "three": "^0.185.1"
  },
  "dependencies": {
    "sharp": "^0.35.3"
  }
}
