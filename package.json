{
  "name": "the-greatest-shortcoming",
  "version": "0.2.0",
  "private": true,
  "description": "Jekyll site for The Greatest Shortcoming. Tailwind CSS built via Vite; islands TypeScript bundle (paused) built via esbuild.",
  "type": "module",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i assets/css/src/main.css -o assets/css/dist/main.css --minify",
    "dev:css": "tailwindcss -i assets/css/src/main.css -o assets/css/dist/main.css --watch",
    "build:islands": "node esbuild.config.mjs",
    "build:islands:watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.16",
    "d3": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scroll": "^1.9.3",
    "react-scrollama": "^2.4.2",
    "scrollama": "^3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/d3": "^7.4.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-scroll": "^1.8.10",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  }
}
